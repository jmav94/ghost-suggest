{
  "name": "ghost-suggest",
  "version": "0.1.0",
  "description": "AI-powered terminal suggestions using local LLMs. Watches your session and suggests the next step.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ghost-suggest": "dist/index.js",
    "gs": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc",
    "start": "node dist/index.js"
  },
  "keywords": [
    "terminal",
    "ai",
    "autocomplete",
    "suggestions",
    "ollama",
    "llm",
    "claude",
    "cli",
    "pty",
    "ghost-text"
  ],
  "author": "WakeCode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmav94/ghost-suggest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": ["darwin", "linux"],
  "dependencies": {
    "node-pty-prebuilt-multiarch": "^0.10.1-pre.5",
    "ollama": "^0.6.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
